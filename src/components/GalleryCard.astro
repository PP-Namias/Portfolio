---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import ImageWrapper from "./misc/ImageWrapper.astro";

interface Props {
	class?: string;
	entry: CollectionEntry<"gallery">;
	title: string;
	url: string;
	published: Date;
	updated?: Date;
	tags: string[];
	category: string;
	description: string;
	location: string;
	camera: string;
	style: string;
}

const {
	entry,
	title,
	url,
	published,
	updated,
	tags,
	category,
	description,
	location,
	camera,
	style,
} = Astro.props;
const className = Astro.props.class;

// Get a preview image from the gallery collection
const previewImage = "demo-banner.png"; // Using placeholder for now
const hasPreview = true;

const coverWidth = "35%";
---

<div class:list={["gallery-card-base flex flex-col-reverse md:flex-col w-full rounded-[var(--radius-large)] overflow-hidden relative", className]} style={style}>
    <div class:list={["pl-6 md:pl-9 pr-6 md:pr-2 pt-6 md:pt-7 pb-6 relative", {"w-full md:w-[calc(100%_-_52px_-_12px)]": !hasPreview, "w-full md:w-[calc(100%_-_var(--coverWidth)_-_12px)]": hasPreview}]}>
        <a href={url}
           class="transition group w-full block font-bold mb-3 text-3xl text-90
        hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
        active:text-[var(--title-active)] dark:active:text-[var(--title-active)]
        before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
        before:absolute before:top-[35px] before:left-[18px] before:hidden md:before:block
        ">
            {title}
            <Icon class="inline text-[2rem] text-[var(--primary)] md:hidden translate-y-0.5 absolute" name="material-symbols:chevron-right-rounded" ></Icon>
            <Icon class="text-[var(--primary)] text-[2rem] transition hidden md:inline absolute translate-y-0.5 opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0" name="material-symbols:chevron-right-rounded"></Icon>
        </a>

        <!-- Gallery metadata -->
        <div class="flex flex-wrap gap-4 mb-4 text-sm">
            <div class="flex items-center gap-2 text-[var(--meta-text)]">
                <Icon name="material-symbols:calendar-month" class="text-base" />
                <span>{published.toLocaleDateString()}</span>
            </div>
            {category && (
                <div class="flex items-center gap-2 text-[var(--meta-text)]">
                    <Icon name="material-symbols:category" class="text-base" />
                    <span>{category}</span>
                </div>
            )}
            {location && (
                <div class="flex items-center gap-2 text-[var(--meta-text)]">
                    <Icon name="material-symbols:location-on" class="text-base" />
                    <span>{location}</span>
                </div>
            )}
        </div>

        <!-- Description -->
        <div class="transition text-75 mb-3.5 pr-4 line-clamp-2">
            {description}
        </div>

        <!-- Camera info and tags -->
        <div class="flex flex-col gap-2">
            {camera && (
                <div class="text-sm text-black/30 dark:text-white/30 flex items-center gap-2">
                    <Icon name="material-symbols:photo-camera" class="text-base" />
                    <span>{camera}</span>
                </div>
            )}
            
            {tags && tags.length > 0 && (
                <div class="flex flex-wrap gap-1">
                    {tags.slice(0, 3).map(tag => (
                        <span class="px-2 py-1 text-xs rounded-full bg-[var(--tag-bg)] text-[var(--tag-text)] transition hover:bg-[var(--tag-bg-hover)]">
                            {tag}
                        </span>
                    ))}
                    {tags.length > 3 && (
                        <span class="px-2 py-1 text-xs rounded-full bg-[var(--tag-bg)] text-[var(--tag-text)]">
                            +{tags.length - 3}
                        </span>
                    )}
                </div>
            )}
        </div>
    </div>

    {hasPreview && <a href={url} aria-label={title}
                    class:list={["group",
                        "max-h-[25vh] md:max-h-none mx-4 mt-4 -mb-2 md:mb-0 md:mx-0 md:mt-0",
                        "md:w-[var(--coverWidth)] relative md:absolute md:top-3 md:bottom-3 md:right-3 rounded-xl overflow-hidden active:scale-95"
                    ]} >
        <div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition"></div>
        <div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center ">
            <Icon name="material-symbols:photo-library"
                  class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-5xl">
            </Icon>
        </div>
        <img src="/src/assets/images/demo-banner.png" alt="Gallery Preview" class="w-full h-full object-cover" />
    </a>}

    {!hasPreview &&
        <a href={url} aria-label={title} class="!hidden md:!flex btn-regular w-[3.25rem]
         absolute right-3 top-3 bottom-3 rounded-xl bg-[var(--enter-btn-bg)]
         hover:bg-[var(--enter-btn-bg-hover)] active:bg-[var(--enter-btn-bg-active)] active:scale-95
        ">
            <Icon name="material-symbols:photo-library" class="text-2xl text-[var(--primary)]"></Icon>
        </a>
    }
</div>

<style>
.gallery-card-base {
    --coverWidth: 35%;
    background: var(--card-bg);
    border: 1px solid var(--line-divider);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.gallery-card-base:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

.gallery-card-base:hover .group img {
    transform: scale(1.05);
}
</style>