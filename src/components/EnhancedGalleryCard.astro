---
// Enhanced Gallery Card Component with Modal Support
export interface Props {
  image: string;
  title: string;
  description: string;
  category: string;
  techStack: string[];
  liveDemo?: string;
  sourceCode?: string;
  detailedImages?: string[];
  features?: string[];
  projectDate?: string;
  client?: string;
}

const { 
  image, 
  title, 
  description, 
  category, 
  techStack, 
  liveDemo, 
  sourceCode, 
  detailedImages = [], 
  features = [],
  projectDate,
  client 
} = Astro.props;

const galleryId = title.replace(/\s+/g, '-').toLowerCase();
---

<div class="gallery-card group cursor-pointer" data-gallery-id={galleryId}>
  <div class="gallery-image-container relative overflow-hidden rounded-t-lg">
    <img 
      src={image} 
      alt={title}
      class="gallery-image w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
    <div class="gallery-overlay absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-70 transition-all duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100">
      <div class="overlay-content text-center transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
        <h3 class="text-xl font-semibold text-white mb-2">{title}</h3>
        <p class="text-sm text-gray-200 mb-3">{category}</p>
        <button class="view-details-btn bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md transition-colors">
          <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
          View Details
        </button>
      </div>
    </div>
    
    <!-- Category Badge -->
    <div class="absolute top-3 left-3">
      <span class="bg-blue-600 text-white text-xs px-2 py-1 rounded-full font-medium">
        {category}
      </span>
    </div>
    
    <!-- Featured Badge (if applicable) -->
    {title.includes('HRIS') || title.includes('Lead') ? (
      <div class="absolute top-3 right-3">
        <span class="bg-yellow-500 text-white text-xs px-2 py-1 rounded-full font-medium">
          ⭐ Featured
        </span>
      </div>
    ) : null}
  </div>
  
  <div class="card-content p-4 bg-white dark:bg-gray-800">
    <div class="flex justify-between items-start mb-2">
      <h4 class="font-semibold text-lg text-gray-900 dark:text-white">{title}</h4>
      {projectDate && (
        <span class="text-xs text-gray-500 dark:text-gray-400">
          {new Date(projectDate).getFullYear()}
        </span>
      )}
    </div>
    
    <p class="text-gray-600 dark:text-gray-300 text-sm mb-3 line-clamp-2">
      {description}
    </p>
    
    {client && (
      <p class="text-xs text-blue-600 dark:text-blue-400 mb-2 font-medium">
        Client: {client}
      </p>
    )}
    
    <div class="tech-stack flex flex-wrap gap-1 mb-3">
      {techStack.slice(0, 4).map(tech => (
        <span class="bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-xs px-2 py-1 rounded-full">
          {tech}
        </span>
      ))}
      {techStack.length > 4 && (
        <span class="text-xs text-gray-500 dark:text-gray-400 px-2 py-1">
          +{techStack.length - 4} more
        </span>
      )}
    </div>
    
    <div class="card-actions flex justify-between items-center">
      <div class="flex gap-2">
        {liveDemo && (
          <a 
            href={liveDemo} 
            class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 text-sm font-medium transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            onclick="event.stopPropagation()"
          >
            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
            Live Demo
          </a>
        )}
        {sourceCode && (
          <a 
            href={sourceCode} 
            class="text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 text-sm font-medium transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            onclick="event.stopPropagation()"
          >
            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
            Code
          </a>
        )}
      </div>
      
      <button class="text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Hidden data for modal -->
  <script type="application/json" class="gallery-data">
    {
      "id": galleryId,
      "title": title,
      "description": description,
      "category": category,
      "techStack": techStack,
      "features": features,
      "liveDemo": liveDemo,
      "sourceCode": sourceCode,
      "detailedImages": detailedImages,
      "mainImage": image,
      "projectDate": projectDate,
      "client": client
    }
  </script>
</div>

<style>
.gallery-card {
  @apply bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 border border-gray-200 dark:border-gray-700;
}

.gallery-card:hover {
  transform: translateY(-4px);
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>