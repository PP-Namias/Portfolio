---
// Enhanced Gallery Card Component with Modal Support - Following Best Practices Guide
export interface Props {
  image: string;
  title: string;
  description: string;
  category: string;
  techStack: string[];
  liveDemo?: string;
  sourceCode?: string;
  detailedImages?: string[];
  features?: string[];
  projectDate?: string;
  client?: string;
  challenges?: string[];
  solutions?: string[];
  results?: string[];
  teamSize?: number;
  duration?: string;
  featured?: boolean;
}

const { 
  image, 
  title, 
  description, 
  category, 
  techStack, 
  liveDemo, 
  sourceCode, 
  detailedImages = [], 
  features = [],
  projectDate,
  client,
  challenges = [],
  solutions = [],
  results = [],
  teamSize,
  duration,
  featured = false
} = Astro.props;

const galleryId = title.replace(/\s+/g, '-').toLowerCase();
---

<div 
  class="gallery-card group cursor-pointer" 
  data-gallery-id={galleryId}
  data-title={title}
  data-description={description}
  data-category={category}
  data-tech-stack={JSON.stringify(techStack)}
  data-live-demo={liveDemo}
  data-source-code={sourceCode}
  data-detailed-images={JSON.stringify(detailedImages)}
  data-features={JSON.stringify(features)}
  data-challenges={JSON.stringify(challenges)}
  data-solutions={JSON.stringify(solutions)}
  data-results={JSON.stringify(results)}
  data-project-date={projectDate}
  data-client={client}
  data-team-size={teamSize}
  data-duration={duration}
  tabindex="0"
  role="button"
  aria-label={`View details for ${title} project`}
>
  <div class="gallery-image-container relative overflow-hidden rounded-t-lg">
    <img 
      src={image} 
      alt={title}
      class="gallery-image w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
    <div class="gallery-overlay absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-70 transition-all duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100">
      <div class="overlay-content text-center transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
        <h3 class="text-xl font-semibold text-white mb-2">{title}</h3>
        <p class="text-sm text-gray-200 mb-3">{category}</p>
        <button class="view-details-btn bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
          <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
          View Details
        </button>
      </div>
    </div>
    
    <!-- Category Badge -->
    <div class="absolute top-3 left-3">
      <span class="bg-blue-600 text-white text-xs px-2 py-1 rounded-full font-medium">
        {category}
      </span>
    </div>
    
    <!-- Featured Badge -->
    {featured && (
      <div class="absolute top-3 right-3">
        <span class="bg-gradient-to-r from-yellow-400 to-orange-500 text-white text-xs px-2 py-1 rounded-full font-medium shadow-md">
          ⭐ Featured
        </span>
      </div>
    )}
  </div>
  
  <div class="card-content p-4 bg-white dark:bg-gray-800">
    <div class="flex justify-between items-start mb-2">
      <h4 class="font-semibold text-lg text-gray-900 dark:text-white">{title}</h4>
      {projectDate && (
        <span class="text-xs text-gray-500 dark:text-gray-400">
          {new Date(projectDate).getFullYear()}
        </span>
      )}
    </div>
    
    <p class="text-gray-600 dark:text-gray-300 text-sm mb-3 line-clamp-2">
      {description}
    </p>
    
    {client && (
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
        </svg>
        <p class="text-xs text-blue-600 dark:text-blue-400 font-medium">
          {client}
        </p>
      </div>
    )}
    
    {(teamSize || duration) && (
      <div class="flex items-center gap-4 mb-2 text-xs text-gray-500 dark:text-gray-400">
        {teamSize && (
          <div class="flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
            </svg>
            <span>{teamSize} team</span>
          </div>
        )}
        {duration && (
          <div class="flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{duration}</span>
          </div>
        )}
      </div>
    )}
    
    <div class="tech-stack flex flex-wrap gap-1 mb-3">
      {techStack.slice(0, 4).map(tech => (
        <span class="bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-xs px-2 py-1 rounded-full font-medium transition-transform hover:scale-105">
          {tech}
        </span>
      ))}
      {techStack.length > 4 && (
        <span class="text-xs text-gray-500 dark:text-gray-400 px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded-full">
          +{techStack.length - 4} more
        </span>
      )}
    </div>
    
    <div class="card-actions flex justify-between items-center">
      <div class="flex gap-2">
        {liveDemo && (
          <a 
            href={liveDemo} 
            class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 text-sm font-medium transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            onclick="event.stopPropagation()"
          >
            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
            Live Demo
          </a>
        )}
        {sourceCode && (
          <a 
            href={sourceCode} 
            class="text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 text-sm font-medium transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            onclick="event.stopPropagation()"
          >
            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
            Code
          </a>
        )}
      </div>
      
      <button class="text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Enhanced data for modal -->
  <script type="application/json" class="gallery-data">
    {
      "id": galleryId,
      "title": title,
      "description": description,
      "category": category,
      "techStack": techStack,
      "features": features,
      "challenges": challenges,
      "solutions": solutions,
      "results": results,
      "liveDemo": liveDemo,
      "sourceCode": sourceCode,
      "detailedImages": detailedImages,
      "mainImage": image,
      "projectDate": projectDate,
      "client": client,
      "teamSize": teamSize,
      "duration": duration,
      "featured": featured
    }
  </script>
</div>

<style>
.gallery-card {
  @apply bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-xl transition-all duration-300 border border-gray-200 dark:border-gray-700;
  transform: translateY(0);
}

.gallery-card:hover {
  transform: translateY(-4px);
}

.gallery-card:focus {
  outline: 2px solid #3b82f6;
  outline-offset: 2px;
}

.gallery-card:focus-visible {
  ring: 2px;
  ring-color: #3b82f6;
  ring-offset: 2px;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Enhanced animations */
.gallery-card .tech-stack span {
  transition: all 0.2s ease;
}

.gallery-card:hover .tech-stack span {
  transform: scale(1.05);
}

.view-details-btn {
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
}

.view-details-btn:hover {
  box-shadow: 0 6px 16px rgba(59, 130, 246, 0.4);
}

/* Responsive adjustments */
@media (max-width: 768px) {
  .gallery-card {
    margin-bottom: 1rem;
  }
  
  .card-content {
    padding: 1rem;
  }
  
  .tech-stack {
    gap: 0.25rem;
  }
  
  .tech-stack span {
    font-size: 0.625rem;
    padding: 0.25rem 0.5rem;
  }
}

/* Dark mode enhancements */
@media (prefers-color-scheme: dark) {
  .gallery-card {
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
  
  .gallery-card:hover {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }
}

/* Animation for overlay content */
.gallery-overlay .overlay-content {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.gallery-card:hover .gallery-overlay .overlay-content {
  transform: translateY(0) scale(1);
}

/* Professional gradient overlays */
.gallery-overlay {
  background: linear-gradient(
    135deg,
    rgba(59, 130, 246, 0.8) 0%,
    rgba(147, 51, 234, 0.8) 100%
  );
}
</style>