</style>

<script>
  // Analytics functionality
  class SkillsAnalytics {
    constructor() {
      this.setupEventListeners();
      this.animateCharts();
      this.setupExportFunctionality();
    }

    private setupEventListeners(): void {
      const refreshBtn = document.getElementById('refresh-analytics');
      const exportBtn = document.getElementById('export-analytics');

      refreshBtn?.addEventListener('click', () => {
        this.refreshAnalytics();
      });

      exportBtn?.addEventListener('click', () => {
        this.exportAnalytics();
      });
    }

    private animateCharts(): void {
      // Animate category bars
      const categoryFills = document.querySelectorAll('.category-fill');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const fill = entry.target as HTMLElement;
            fill.style.width = '0%';
            requestAnimationFrame(() => {
              fill.style.width = fill.dataset.width || fill.style.width;
            });
            observer.unobserve(entry.target);
          }
        });
      });

      categoryFills.forEach(fill => {
        const currentWidth = (fill as HTMLElement).style.width;
        (fill as HTMLElement).dataset.width = currentWidth;
        observer.observe(fill);
      });

      // Animate progress bars
      const progressFills = document.querySelectorAll('.progress-fill, .level-fill');
      progressFills.forEach(fill => {
        observer.observe(fill);
      });
    }

    private refreshAnalytics(): void {
      const refreshBtn = document.getElementById('refresh-analytics');
      if (refreshBtn) {
        refreshBtn.innerHTML = '<svg class="animate-spin w-4 h-4" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" opacity="0.25"></circle><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" opacity="0.75"></path></svg> Refreshing...';
        
        setTimeout(() => {
          refreshBtn.innerHTML = '<i class="w-4 h-4" data-lucide="refresh-cw"></i> Refresh Data';
          this.animateCharts();
        }, 2000);
      }
    }

    private exportAnalytics(): void {
      const analyticsData = {
        timestamp: new Date().toISOString(),
        skills: {
          total: document.querySelector('.metric-value')?.textContent,
          categories: Array.from(document.querySelectorAll('.category-name')).map(el => el.textContent),
          trending: Array.from(document.querySelectorAll('.skill-name')).map(el => el.textContent)
        },
        goals: Array.from(document.querySelectorAll('.goal-title')).map(el => el.textContent)
      };

      const dataStr = JSON.stringify(analyticsData, null, 2);
      const dataBlob = new Blob([dataStr], { type: 'application/json' });
      const url = URL.createObjectURL(dataBlob);
      
      const link = document.createElement('a');
      link.href = url;
      link.download = `skills-analytics-${new Date().toISOString().split('T')[0]}.json`;
      link.click();
      
      URL.revokeObjectURL(url);
    }

    private setupExportFunctionality(): void {
      // Setup CSV export for detailed analytics
      const exportCSV = () => {
        const csvData = [
          ['Skill', 'Category', 'Level', 'Experience', 'Projects'],
          // This would be populated with actual skill data
        ];
        
        const csvContent = csvData.map(row => row.join(',')).join('\n');
        const blob = new Blob([csvContent], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        
        const link = document.createElement('a');
        link.href = url;
        link.download = 'skills-detailed-report.csv';
        link.click();
        
        URL.revokeObjectURL(url);
      };

      // Add to export options
      window.exportSkillsCSV = exportCSV;
    }
  }

  // Initialize analytics when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new SkillsAnalytics();
  });
</script>