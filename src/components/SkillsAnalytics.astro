---
// Skills Analytics Dashboard Component
// src/components/SkillsAnalytics.astro
import { Icon } from "astro-icon/components";
import { skillsDatabase, getSkillStats, getTrendingSkills } from "../data/skillsConfig";

const skillStats = getSkillStats();
const trendingSkills = getTrendingSkills();

// Calculate category distributions
const categoryData = Object.entries(skillsDatabase).map(([category, skills]) => ({
  category,
  count: skills.length,
  averageLevel: Math.round(skills.reduce((sum, skill) => sum + skill.level, 0) / skills.length),
  expertCount: skills.filter(skill => skill.level >= 90).length,
  totalProjects: [...new Set(skills.flatMap(skill => skill.projects))].length
}));

// Experience distribution
const experienceGroups = {
  junior: { count: 0, skills: [] as string[] },
  intermediate: { count: 0, skills: [] as string[] },
  senior: { count: 0, skills: [] as string[] },
  expert: { count: 0, skills: [] as string[] }
};

Object.values(skillsDatabase).flat().forEach(skill => {
  if (skill.level < 60) {
    experienceGroups.junior.count++;
    experienceGroups.junior.skills.push(skill.name);
  } else if (skill.level < 75) {
    experienceGroups.intermediate.count++;
    experienceGroups.intermediate.skills.push(skill.name);
  } else if (skill.level < 90) {
    experienceGroups.senior.count++;
    experienceGroups.senior.skills.push(skill.name);
  } else {
    experienceGroups.expert.count++;
    experienceGroups.expert.skills.push(skill.name);
  }
});
---

<div class="skills-analytics-dashboard">
  <!-- Dashboard Header -->
  <div class="dashboard-header">
    <div class="header-content">
      <h2 class="dashboard-title">
        <Icon name="material-symbols:analytics" class="title-icon" />
        Skills Analytics Dashboard
      </h2>
      <p class="dashboard-subtitle">
        Comprehensive analysis of technical expertise and growth trajectory
      </p>
    </div>
    <div class="dashboard-actions">
      <button class="export-btn" id="export-analytics">
        <Icon name="material-symbols:download" class="w-4 h-4" />
        Export Report
      </button>
      <button class="refresh-btn" id="refresh-analytics">
        <Icon name="material-symbols:refresh" class="w-4 h-4" />
        Refresh Data
      </button>
    </div>
  </div>

  <!-- Key Metrics Overview -->
  <div class="metrics-overview">
    <div class="metric-card">
      <div class="metric-header">
        <Icon name="material-symbols:code" class="metric-icon text-blue-500" />
        <span class="metric-label">Total Skills</span>
      </div>
      <div class="metric-value">{skillStats.totalSkills}</div>
      <div class="metric-trend positive">
        <Icon name="material-symbols:trending-up" class="trend-icon" />
        +2 this month
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-header">
        <Icon name="material-symbols:speed" class="metric-icon text-green-500" />
        <span class="metric-label">Average Level</span>
      </div>
      <div class="metric-value">{skillStats.averageLevel}%</div>
      <div class="metric-trend positive">
        <Icon name="material-symbols:trending-up" class="trend-icon" />
        +3% growth
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-header">
        <Icon name="material-symbols:workspace-premium" class="metric-icon text-purple-500" />
        <span class="metric-label">Expert Level</span>
      </div>
      <div class="metric-value">{skillStats.expertLevel}</div>
      <div class="metric-trend positive">
        <Icon name="material-symbols:trending-up" class="trend-icon" />
        +1 this quarter
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-header">
        <Icon name="material-symbols:folder-open" class="metric-icon text-orange-500" />
        <span class="metric-label">Total Projects</span>
      </div>
      <div class="metric-value">{skillStats.totalProjects}</div>
      <div class="metric-trend stable">
        <Icon name="material-symbols:trending-flat" class="trend-icon" />
        Stable
      </div>
    </div>
  </div>

  <!-- Charts Section -->
  <div class="charts-section">
    <!-- Category Distribution Chart -->
    <div class="chart-container">
      <div class="chart-header">
        <h3 class="chart-title">Skills by Category</h3>
        <div class="chart-subtitle">Distribution across technology domains</div>
      </div>
      <div class="category-chart">
        {categoryData.map(category => (
          <div class="category-bar-container">
            <div class="category-info">
              <span class="category-name">{category.category}</span>
              <span class="category-count">{category.count} skills</span>
            </div>
            <div class="category-bar">
              <div 
                class="category-fill"
                style={`width: ${(category.count / skillStats.totalSkills) * 100}%`}
                data-category={category.category}
              ></div>
            </div>
            <div class="category-stats">
              <span class="avg-level">Avg: {category.averageLevel}%</span>
              <span class="expert-count">{category.expertCount} expert</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Experience Level Distribution -->
    <div class="chart-container">
      <div class="chart-header">
        <h3 class="chart-title">Experience Distribution</h3>
        <div class="chart-subtitle">Skills grouped by proficiency level</div>
      </div>
      <div class="experience-chart">
        <div class="experience-item expert">
          <div class="experience-header">
            <Icon name="material-symbols:star" class="experience-icon" />
            <span class="experience-label">Expert (90%+)</span>
            <span class="experience-count">{experienceGroups.expert.count}</span>
          </div>
          <div class="experience-skills">
            {experienceGroups.expert.skills.slice(0, 3).join(', ')}
            {experienceGroups.expert.skills.length > 3 && ` +${experienceGroups.expert.skills.length - 3} more`}
          </div>
        </div>

        <div class="experience-item senior">
          <div class="experience-header">
            <Icon name="material-symbols:workspace-premium" class="experience-icon" />
            <span class="experience-label">Senior (75-89%)</span>
            <span class="experience-count">{experienceGroups.senior.count}</span>
          </div>
          <div class="experience-skills">
            {experienceGroups.senior.skills.slice(0, 3).join(', ')}
            {experienceGroups.senior.skills.length > 3 && ` +${experienceGroups.senior.skills.length - 3} more`}
          </div>
        </div>

        <div class="experience-item intermediate">
          <div class="experience-header">
            <Icon name="material-symbols:trending-up" class="experience-icon" />
            <span class="experience-label">Intermediate (60-74%)</span>
            <span class="experience-count">{experienceGroups.intermediate.count}</span>
          </div>
          <div class="experience-skills">
            {experienceGroups.intermediate.skills.slice(0, 3).join(', ')}
            {experienceGroups.intermediate.skills.length > 3 && ` +${experienceGroups.intermediate.skills.length - 3} more`}
          </div>
        </div>

        <div class="experience-item junior">
          <div class="experience-header">
            <Icon name="material-symbols:school" class="experience-icon" />
            <span class="experience-label">Learning (<60%)</span>
            <span class="experience-count">{experienceGroups.junior.count}</span>
          </div>
          <div class="experience-skills">
            {experienceGroups.junior.skills.slice(0, 3).join(', ')}
            {experienceGroups.junior.skills.length > 3 && ` +${experienceGroups.junior.skills.length - 3} more`}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trending Skills Section -->
  <div class="trending-section">
    <div class="trending-header">
      <h3 class="trending-title">
        <Icon name="material-symbols:trending-up" class="trending-icon" />
        Trending & Recent Updates
      </h3>
    </div>
    <div class="trending-grid">
      {trendingSkills.map(skill => (
        <div class="trending-skill-card">
          <div class="trending-skill-header">
            <Icon name={skill.icon} class="skill-icon" />
            <div class="skill-info">
              <span class="skill-name">{skill.name}</span>
              <span class="skill-category">{skill.category}</span>
            </div>
            <div class="trending-badge">🔥 Hot</div>
          </div>
          <div class="skill-level-bar">
            <div class="level-fill" style={`width: ${skill.level}%`}></div>
            <span class="level-text">{skill.level}%</span>
          </div>
          <div class="skill-projects">
            <Icon name="material-symbols:folder" class="projects-icon" />
            <span>{skill.projects.length} projects</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Learning Goals Section -->
  <div class="goals-section">
    <div class="goals-header">
      <h3 class="goals-title">
        <Icon name="material-symbols:flag" class="goals-icon" />
        Learning Goals & Roadmap
      </h3>
    </div>
    <div class="goals-grid">
      <div class="goal-card">
        <div class="goal-status in-progress"></div>
        <div class="goal-content">
          <h4 class="goal-title">Advanced React Patterns</h4>
          <p class="goal-description">Master advanced React patterns, performance optimization, and architecture</p>
          <div class="goal-progress">
            <div class="progress-bar">
              <div class="progress-fill" style="width: 75%"></div>
            </div>
            <span class="progress-text">75% Complete</span>
          </div>
        </div>
      </div>

      <div class="goal-card">
        <div class="goal-status planned"></div>
        <div class="goal-content">
          <h4 class="goal-title">Cloud Architecture</h4>
          <p class="goal-description">Deep dive into AWS architecture patterns and serverless computing</p>
          <div class="goal-progress">
            <div class="progress-bar">
              <div class="progress-fill" style="width: 25%"></div>
            </div>
            <span class="progress-text">25% Complete</span>
          </div>
        </div>
      </div>

      <div class="goal-card">
        <div class="goal-status planned"></div>
        <div class="goal-content">
          <h4 class="goal-title">Machine Learning Engineering</h4>
          <p class="goal-description">MLOps, model deployment, and production ML systems</p>
          <div class="goal-progress">
            <div class="progress-bar">
              <div class="progress-fill" style="width: 10%"></div>
            </div>
            <span class="progress-text">10% Complete</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

