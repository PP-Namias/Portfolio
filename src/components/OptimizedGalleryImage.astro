---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
	src: string | ImageMetadata;
	alt: string;
	width?: number;
	height?: number;
	class?: string;
	loading?: "lazy" | "eager";
	sizes?: string;
	aspectRatio?: string;
	objectFit?: "cover" | "contain" | "fill" | "none" | "scale-down";
	quality?: number;
	format?: "auto" | "webp" | "avif" | "jpeg" | "png" | "svg";
	// Gallery specific props
	isMainImage?: boolean;
	projectTitle?: string;
	index?: number;
}

const {
	src,
	alt,
	width = 800,
	height = 600,
	class: className = "",
	loading = "lazy",
	sizes = "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw",
	aspectRatio = "16:9",
	objectFit = "cover",
	quality = 85,
	format = "webp",
	isMainImage = false,
	projectTitle = "",
	index = 0,
} = Astro.props;

// Generate responsive sizes for different viewports
const responsiveWidths = [400, 600, 800, 1200, 1600];
const mainImageSizes = isMainImage
	? "(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 60vw"
	: sizes;

// Additional classes for gallery images
const galleryClasses = `
  transition-all duration-300 ease-in-out
  ${objectFit === "cover" ? "object-cover" : `object-${objectFit}`}
  ${isMainImage ? "w-full rounded-lg shadow-xl" : "rounded-md shadow-md"}
  ${className}
`.trim();
---

{/* Optimized Gallery Image */}
<div 
  data-gallery-image
  data-project-title={projectTitle}
  data-index={index}
  class={galleryClasses}
>
  {typeof src === 'string' ? (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      class="w-full h-full object-cover"
    />
  ) : (
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      class="w-full h-full object-cover"
    />
  )}
</div>

<style>
  /* Enhanced image loading states */
  img {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: loading 1.5s infinite ease-in-out;
  }

  img[data-loaded="true"] {
    animation: none;
    background: none;
  }

  @keyframes loading {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  /* Hover effects for gallery images */
  img[data-gallery-image="thumbnail"]:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  img[data-gallery-image="main"]:hover {
    transform: scale(1.02);
  }

  /* Responsive behavior */
  @media (max-width: 640px) {
    img[data-gallery-image="main"] {
      border-radius: 0.5rem;
    }
  }

  /* Dark mode support */
  @media (prefers-color-scheme: dark) {
    img {
      background: linear-gradient(90deg, #2a2a2a 25%, #1a1a1a 50%, #2a2a2a 75%);
    }
  }

  /* Performance optimization */
  img {
    content-visibility: auto;
    contain-intrinsic-size: 800px 600px;
  }
</style>

<script>
  // Type declaration for Google Analytics gtag function
  declare global {
    interface Window {
      gtag: (...args: any[]) => void;
    }
    var gtag: (...args: any[]) => void;
  }

  // Enhanced image loading behavior with analytics
  document.addEventListener('DOMContentLoaded', function() {
    const images = document.querySelectorAll('[data-gallery-image]');
    
    // Performance tracking
    const imageLoadTimes = new Map();
    
    // Intersection Observer for better loading control
    const imageObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const img = entry.target as HTMLImageElement;
          const startTime = performance.now();
          
          img.addEventListener('load', function() {
            const loadTime = performance.now() - startTime;
            img.setAttribute('data-loaded', 'true');
            
            // Track image loading performance
            if (typeof gtag !== 'undefined') {
              gtag('event', 'gallery_image_loaded', {
                event_category: 'performance',
                event_label: img.dataset.projectTitle || 'unknown',
                value: Math.round(loadTime),
                custom_parameters: {
                  image_index: img.dataset.imageIndex,
                  image_type: img.dataset.galleryImage,
                  load_time_ms: Math.round(loadTime)
                }
              });
            }
            
            imageLoadTimes.set(img, loadTime);
          });
          
          img.addEventListener('error', function() {
            console.error('Failed to load gallery image:', img.src);
            
            // Track image loading errors
            if (typeof gtag !== 'undefined') {
              gtag('event', 'gallery_image_error', {
                event_category: 'error',
                event_label: img.dataset.projectTitle || 'unknown',
                custom_parameters: {
                  image_src: img.src,
                  image_index: img.dataset.imageIndex
                }
              });
            }
            
            // Fallback placeholder
            img.style.backgroundColor = '#f3f4f6';
            img.alt = 'Image failed to load';
          });
          
          imageObserver.unobserve(img);
        }
      });
    }, {
      rootMargin: '50px 0px',
      threshold: 0.1
    });
    
    // Observe all gallery images
    images.forEach(img => imageObserver.observe(img));
    
    // Track overall gallery image performance
    window.addEventListener('load', function() {
      setTimeout(() => {
        const totalImages = images.length;
        const loadedImages = document.querySelectorAll('[data-loaded="true"]').length;
        
        if (typeof gtag !== 'undefined') {
          gtag('event', 'gallery_images_performance', {
            event_category: 'performance',
            custom_parameters: {
              total_images: totalImages,
              loaded_images: loadedImages,
              load_success_rate: Math.round((loadedImages / totalImages) * 100)
            }
          });
        }
      }, 2000);
    });
  });
</script>