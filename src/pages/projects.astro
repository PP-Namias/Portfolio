---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const projectsPost = await getEntry("spec", "projects");

if (!projectsPost) {
	throw new Error("Projects page content not found");
}

const { Content } = await render(projectsPost);
---

<MainGridLayout title="Projects - Jhon Keneth Namias" description="Explore my latest work and achievements">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>

<style>
    /* Enhanced styling for projects content */
    :global(.card-base h1) {
        @apply text-4xl font-bold mb-8 text-center;
    }
    
    :global(.card-base h2) {
        @apply text-2xl font-semibold mb-6 text-center text-gray-600;
    }
    
    :global(.card-base h3) {
        @apply text-xl font-bold mb-4 text-gray-800;
    }
    
    :global(.card-base p) {
        @apply text-gray-600 leading-relaxed mb-4;
    }
    
    :global(.card-base strong) {
        @apply font-semibold text-gray-800;
    }
    
    :global(.card-base hr) {
        @apply border-gray-200 my-8;
    }
    
    /* Technology tags styling */
    :global(.card-base p:has(strong:contains("Technologies:"))) {
        @apply bg-gray-50 p-4 rounded-lg border-l-4 border-blue-500 mb-4;
    }
    
    /* Project sections spacing */
    :global(.card-base h2:first-of-type) {
        @apply mt-0;
    }
    
    /* Button styling enhancements */
    :global(.card-base a) {
        @apply no-underline;
    }
    
    /* Project title styling */
    :global(.card-base h2:not(:first-child):not(:nth-child(2))) {
        @apply text-2xl font-bold text-left text-gray-900 mt-12 mb-4;
    }
    
    /* GitHub Activity section */
    :global(.card-base h2:contains("GitHub Activity")) {
        @apply text-3xl font-semibold text-center mb-8;
    }
    
    /* Responsive design */
    @media (max-width: 768px) {
        :global(.card-base) {
            @apply px-6 py-4;
        }
        
        :global(.card-base h1) {
            @apply text-3xl mb-6;
        }
        
        :global(.card-base h2) {
            @apply text-xl mb-4;
        }
        
        :global(.card-base .flex) {
            @apply flex-col gap-2;
        }
        
        :global(.card-base .grid) {
            @apply grid-cols-1 gap-4;
        }
    }
</style>