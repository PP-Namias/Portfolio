---
import { getSortedProjects, getFeaturedProjects } from "../utils/project-utils";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

// Get all projects, sorted by featured first, then by published date
const allProjects = await getSortedProjects();
const featuredProjects = await getFeaturedProjects();
const otherProjects = allProjects.filter(project => !project.data.featured);
---

<MainGridLayout title="Projects - Jhon Keneth Namias" description="Explore my latest work and achievements">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            
            <!-- Page Header -->
            <div class="text-center mb-12">
                <h1 class="text-5xl font-bold mb-4 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                    Featured Projects
                </h1>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
                    Explore my latest work and achievements in AI, automation, and full-stack development. 
                    Each project represents a unique challenge solved with innovative technology.
                </p>
            </div>

            <!-- Featured Projects Section -->
            {featuredProjects.length > 0 && (
                <section class="mb-16">
                    <h2 class="text-3xl font-bold mb-8 flex items-center gap-3 text-gray-800">
                        <Icon name="fa6-solid:star" class="w-8 h-8 text-yellow-500" />
                        Spotlight Projects
                    </h2>
                    
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                        {featuredProjects.map((project) => (
                            <article class="group bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
                                
                                {/* Project Image */}
                                {project.data.image && (
                                    <div class="aspect-video bg-gradient-to-br from-blue-50 to-purple-50 relative overflow-hidden">
                                        <img 
                                            src={project.data.image} 
                                            alt={project.data.title}
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                            loading="lazy"
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                                        
                                        {/* Featured Badge */}
                                        <div class="absolute top-4 right-4 px-3 py-1 bg-gradient-to-r from-yellow-400 to-orange-500 text-white text-sm font-semibold rounded-full">
                                            <Icon name="fa6-solid:star" class="w-3 h-3 inline mr-1" />
                                            Featured
                                        </div>
                                    </div>
                                )}
                                
                                {/* Project Content */}
                                <div class="p-8">
                                    <div class="mb-4">
                                        <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors">
                                            <a href={`/projects/${project.slug}/`} class="hover:underline">
                                                {project.data.title}
                                            </a>
                                        </h3>
                                        <p class="text-gray-600 leading-relaxed line-clamp-3">
                                            {project.data.description}
                                        </p>
                                    </div>
                                    
                                    {/* Technologies */}
                                    {project.data.technologies && project.data.technologies.length > 0 && (
                                        <div class="mb-6">
                                            <div class="flex flex-wrap gap-2">
                                                {project.data.technologies.slice(0, 4).map((tech) => (
                                                    <span class="px-3 py-1 bg-blue-100 text-blue-800 text-sm font-medium rounded-full">
                                                        {tech}
                                                    </span>
                                                ))}
                                                {project.data.technologies.length > 4 && (
                                                    <span class="px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">
                                                        +{project.data.technologies.length - 4} more
                                                    </span>
                                                )}
                                            </div>
                                        </div>
                                    )}
                                    
                                    {/* Action Buttons */}
                                    <div class="flex flex-wrap gap-3">
                                        <a 
                                            href={`/projects/${project.slug}/`}
                                            class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold rounded-lg hover:from-blue-600 hover:to-blue-700 transition-all duration-200 transform hover:scale-105 shadow-md hover:shadow-lg"
                                        >
                                            <Icon name="fa6-solid:arrow-right" class="w-4 h-4" />
                                            View Details
                                        </a>
                                        
                                        {project.data.demoUrl && (
                                            <a 
                                                href={project.data.demoUrl}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-green-500 to-green-600 text-white font-semibold rounded-lg hover:from-green-600 hover:to-green-700 transition-all duration-200 transform hover:scale-105 shadow-md hover:shadow-lg"
                                            >
                                                <Icon name="fa6-solid:external-link" class="w-4 h-4" />
                                                Live Demo
                                            </a>
                                        )}
                                        
                                        {project.data.codeUrl && (
                                            <a 
                                                href={project.data.codeUrl}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-gray-700 to-gray-800 text-white font-semibold rounded-lg hover:from-gray-800 hover:to-gray-900 transition-all duration-200 transform hover:scale-105 shadow-md hover:shadow-lg"
                                            >
                                                <Icon name="fa6-brands:github" class="w-4 h-4" />
                                                Code
                                            </a>
                                        )}
                                    </div>
                                </div>
                            </article>
                        ))}
                    </div>
                </section>
            )}

            <!-- Other Projects Section -->
            {otherProjects.length > 0 && (
                <section>
                    <h2 class="text-3xl font-bold mb-8 flex items-center gap-3 text-gray-800">
                        <Icon name="fa6-solid:folder-open" class="w-8 h-8 text-blue-500" />
                        Other Projects
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {otherProjects.map((project) => (
                            <article class="group bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
                                
                                {/* Project Image */}
                                {project.data.image && (
                                    <div class="aspect-video bg-gradient-to-br from-gray-50 to-blue-50 relative overflow-hidden">
                                        <img 
                                            src={project.data.image} 
                                            alt={project.data.title}
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                            loading="lazy"
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
                                    </div>
                                )}
                                
                                {/* Project Content */}
                                <div class="p-6">
                                    <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
                                        <a href={`/projects/${project.slug}/`} class="hover:underline">
                                            {project.data.title}
                                        </a>
                                    </h3>
                                    <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-2">
                                        {project.data.description}
                                    </p>
                                    
                                    {/* Technologies (limited) */}
                                    {project.data.technologies && project.data.technologies.length > 0 && (
                                        <div class="mb-4">
                                            <div class="flex flex-wrap gap-1">
                                                {project.data.technologies.slice(0, 3).map((tech) => (
                                                    <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs font-medium rounded">
                                                        {tech}
                                                    </span>
                                                ))}
                                                {project.data.technologies.length > 3 && (
                                                    <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded">
                                                        +{project.data.technologies.length - 3}
                                                    </span>
                                                )}
                                            </div>
                                        </div>
                                    )}
                                    
                                    {/* Action Button */}
                                    <a 
                                        href={`/projects/${project.slug}/`}
                                        class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-semibold text-sm transition-colors"
                                    >
                                        Learn More
                                        <Icon name="fa6-solid:arrow-right" class="w-3 h-3" />
                                    </a>
                                </div>
                            </article>
                        ))}
                    </div>
                </section>
            )}

            <!-- Call to Action -->
            <div class="mt-16 text-center p-8 bg-gradient-to-r from-blue-50 to-purple-50 rounded-2xl border border-blue-100">
                <h3 class="text-2xl font-bold text-gray-900 mb-4">Interested in Collaboration?</h3>
                <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
                    I'm always excited to work on innovative projects that push the boundaries of technology. 
                    Let's discuss how we can create something amazing together.
                </p>
                <div class="flex flex-wrap justify-center gap-4">
                    <a 
                        href="/contact/"
                        class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold rounded-lg hover:from-blue-600 hover:to-blue-700 transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl"
                    >
                        <Icon name="fa6-solid:envelope" class="w-4 h-4" />
                        Get In Touch
                    </a>
                    <a 
                        href="https://github.com/PP-Namias"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-gray-700 to-gray-800 text-white font-semibold rounded-lg hover:from-gray-800 hover:to-gray-900 transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl"
                    >
                        <Icon name="fa6-brands:github" class="w-4 h-4" />
                        View All Code
                    </a>
                </div>
            </div>
        </div>
    </div>
</MainGridLayout>

<style>
    /* Enhanced styling for projects page */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    /* Hover effects for project cards */
    article:hover {
        transform: translateY(-8px);
    }
    
    /* Gradient overlays for project images */
    .aspect-video::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 50%;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.1));
        pointer-events: none;
    }
    
    /* Button hover animations */
    a[class*="gradient"]:hover {
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }
    
    /* Technology tag styling */
    .bg-blue-100 {
        background-color: rgba(219, 234, 254, 0.8);
        backdrop-filter: blur(4px);
    }
    
    /* Enhanced card shadows */
    article {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 
                    0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }
    
    article:hover {
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 
                    0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }
    
    /* Responsive design improvements */
    @media (max-width: 768px) {
        .card-base {
            @apply px-6 py-4;
        }
        
        h1 {
            @apply text-3xl mb-6;
        }
        
        h2 {
            @apply text-2xl mb-6;
        }
        
        .grid {
            @apply gap-4;
        }
        
        article .p-8 {
            @apply p-6;
        }
        
        article .p-6 {
            @apply p-4;
        }
    }
    
    /* Loading animation for images */
    img {
        transition: opacity 0.3s ease-in-out;
    }
    
    img[loading="lazy"] {
        opacity: 0;
        animation: fadeIn 0.5s ease-in-out forwards;
    }
    
    @keyframes fadeIn {
        to {
            opacity: 1;
        }
    }
    
    /* Focus states for accessibility */
    a:focus {
        outline: 2px solid #3b82f6;
        outline-offset: 2px;
    }
    
    /* Enhanced gradient text */
    .bg-gradient-to-r.bg-clip-text {
        background-size: 200% 200%;
        animation: gradientShift 3s ease infinite;
    }
    
    @keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
    }
</style>