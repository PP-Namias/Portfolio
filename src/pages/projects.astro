---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const projectsPost = await getEntry("spec", "projects");

if (!projectsPost) {
	throw new Error("Projects page content not found");
}

const { Content } = await render(projectsPost);
---

<MainGridLayout title="Projects - Jhon Keneth Namias" description="Explore my latest work and achievements">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>

<style>
    /* Enhanced styling for projects page */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    /* Hover effects for project cards */
    article:hover {
        transform: translateY(-8px);
    }
    
    /* Gradient overlays for project images */
    .aspect-video::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 50%;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.1));
        pointer-events: none;
    }
    
    /* Button hover animations */
    a[class*="gradient"]:hover {
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }
    
    /* Technology tag styling */
    .bg-blue-100 {
        background-color: rgba(219, 234, 254, 0.8);
        backdrop-filter: blur(4px);
    }
    
    /* Enhanced card shadows */
    article {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 
                    0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }
    
    article:hover {
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 
                    0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }
    
    /* Responsive design improvements */
    @media (max-width: 768px) {
        .card-base {
            @apply px-6 py-4;
        }
        
        h1 {
            @apply text-3xl mb-6;
        }
        
        h2 {
            @apply text-2xl mb-6;
        }
        
        .grid {
            @apply gap-4;
        }
        
        article .p-8 {
            @apply p-6;
        }
        
        article .p-6 {
            @apply p-4;
        }
    }
    
    /* Loading animation for images */
    img {
        transition: opacity 0.3s ease-in-out;
    }
    
    img[loading="lazy"] {
        opacity: 0;
        animation: fadeIn 0.5s ease-in-out forwards;
    }
    
    @keyframes fadeIn {
        to {
            opacity: 1;
        }
    }
    
    /* Focus states for accessibility */
    a:focus {
        outline: 2px solid #3b82f6;
        outline-offset: 2px;
    }
    
    /* Enhanced gradient text */
    .bg-gradient-to-r.bg-clip-text {
        background-size: 200% 200%;
        animation: gradientShift 3s ease infinite;
    }
    
    @keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
    }
</style>