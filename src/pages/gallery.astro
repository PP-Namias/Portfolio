---
import Layout from '../layouts/Layout.astro';
import MainGridLayout from '../layouts/MainGridLayout.astro';
---

<Layout title="Gallery - PP Namias">
    <MainGridLayout>
        <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
            <div class="card-base z-10 px-9 py-6 relative w-full">
                <div class="prose">
                    <h1 class="text-3xl font-bold mb-8">Gallery</h1>
                    
                    <!-- Filter Buttons -->
                    <div class="filter-buttons mb-8">
                        <button class="filter-btn active" data-filter="all">All</button>
                        <button class="filter-btn" data-filter="projects">Projects</button>
                        <button class="filter-btn" data-filter="certificates">Certificates</button>
                        <button class="filter-btn" data-filter="achievements">Achievements</button>
                        <button class="filter-btn" data-filter="events">Events</button>
                    </div>
                    
                    <!-- Gallery Grid -->
                    <div class="gallery-grid" id="gallery-grid">
                        <!-- Project Screenshots -->
                        <div class="gallery-item" data-category="projects">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="E-commerce Platform Dashboard" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">E-commerce Dashboard</h3>
                                    <p class="gallery-description">Admin dashboard interface</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="projects">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Chat Application Interface" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Chat Application</h3>
                                    <p class="gallery-description">Real-time messaging interface</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="projects">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Weather Dashboard" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Weather Dashboard</h3>
                                    <p class="gallery-description">Interactive weather visualization</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Certificates -->
                        <div class="gallery-item" data-category="certificates">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="AWS Certification" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">AWS Certified Developer</h3>
                                    <p class="gallery-description">Amazon Web Services • 2023</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="certificates">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="React Certification" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">React Developer</h3>
                                    <p class="gallery-description">Meta Certification • 2022</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="certificates">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="JavaScript Certification" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">JavaScript Algorithms</h3>
                                    <p class="gallery-description">freeCodeCamp • 2021</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Achievements -->
                        <div class="gallery-item" data-category="achievements">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Hackathon Winner" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Hackathon Winner</h3>
                                    <p class="gallery-description">First place in Tech Innovation 2023</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="achievements">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Open Source Contribution" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Open Source Contributor</h3>
                                    <p class="gallery-description">Hacktoberfest 2023 completion</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="achievements">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Code Review Excellence" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Code Review Excellence</h3>
                                    <p class="gallery-description">Team recognition award</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Events -->
                        <div class="gallery-item" data-category="events">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Tech Conference Speaker" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Conference Speaker</h3>
                                    <p class="gallery-description">DevCon 2023 presentation</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="events">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Workshop Facilitator" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Workshop Facilitator</h3>
                                    <p class="gallery-description">React fundamentals workshop</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="events">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Team Building Event" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Team Building</h3>
                                    <p class="gallery-description">Annual company retreat</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Additional Projects -->
                        <div class="gallery-item" data-category="projects">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Data Visualization" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Data Visualization</h3>
                                    <p class="gallery-description">Business analytics dashboard</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gallery-item" data-category="projects">
                            <div class="gallery-card">
                                <img src="/api/placeholder/400/300" alt="Mobile App Design" class="gallery-image" />
                                <div class="gallery-overlay">
                                    <h3 class="gallery-title">Mobile App UI</h3>
                                    <p class="gallery-description">Task management app design</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </MainGridLayout>
</Layout>

<style>
    .filter-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
    }
    
    .filter-btn {
        background: #f3f4f6;
        color: #374151;
        border: none;
        padding: 0.5rem 1.25rem;
        border-radius: 2rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
    .filter-btn:hover,
    .filter-btn.active {
        background: #3b82f6;
        color: white;
        transform: translateY(-2px);
    }
    
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }
    
    .gallery-item {
        transition: all 0.3s ease;
    }
    
    .gallery-item.hidden {
        display: none;
    }
    
    .gallery-card {
        position: relative;
        border-radius: 0.75rem;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .gallery-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }
    
    .gallery-image {
        width: 100%;
        height: 250px;
        object-fit: cover;
        transition: transform 0.3s ease;
    }
    
    .gallery-card:hover .gallery-image {
        transform: scale(1.05);
    }
    
    .gallery-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
        color: white;
        padding: 1.5rem;
        transform: translateY(20px);
        opacity: 0;
        transition: all 0.3s ease;
    }
    
    .gallery-card:hover .gallery-overlay {
        transform: translateY(0);
        opacity: 1;
    }
    
    .gallery-title {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }
    
    .gallery-description {
        font-size: 0.875rem;
        opacity: 0.9;
    }
    
    @media (max-width: 768px) {
        .gallery-grid {
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 1rem;
        }
        
        .filter-buttons {
            justify-content: flex-start;
            overflow-x: auto;
            padding-bottom: 0.5rem;
        }
        
        .filter-btn {
            white-space: nowrap;
        }
    }
</style>

<script>
    // Gallery filtering functionality
    document.addEventListener('DOMContentLoaded', function() {
        const filterButtons = document.querySelectorAll('.filter-btn');
        const galleryItems = document.querySelectorAll('.gallery-item');
        
        filterButtons.forEach(button => {
            button.addEventListener('click', function() {
                const filter = this.getAttribute('data-filter');
                
                // Update active button
                filterButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
                
                // Filter gallery items
                galleryItems.forEach(item => {
                    const category = item.getAttribute('data-category');
                    
                    if (filter === 'all' || category === filter) {
                        item.classList.remove('hidden');
                    } else {
                        item.classList.add('hidden');
                    }
                });
            });
        });
    });
</script>