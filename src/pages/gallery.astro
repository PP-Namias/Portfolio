                    href="/projects/" 
                    class="inline-flex items-center bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-900 dark:text-white px-8 py-3 rounded-lg transition-all duration-300 font-medium"
                >
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    View All Projects
                </a>
            </div>
        </div>
    </div>

    <!-- Gallery Modal -->
    <GalleryModal />
</MainGridLayout>

<style>
/* Gallery Best Practices - Enhanced Styling */
.gallery-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1rem;
}

.gallery-controls {
  border: 1px solid rgba(229, 231, 235, 0.5);
  backdrop-filter: blur(10px);
}

.filter-btn {
  @apply px-4 py-2 text-sm font-medium rounded-full border border-gray-300 dark:border-gray-600 
         text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 
         hover:bg-gray-50 dark:hover:bg-gray-700 transition-all duration-200;
}

.filter-btn.active {
  @apply bg-blue-600 text-white border-blue-600 hover:bg-blue-700 shadow-md;
}

.gallery-grid {
  min-height: 400px;
  transition: all 0.3s ease;
}

.gallery-card.hidden {
  display: none !important;
}

.gallery-card.fade-out {
  opacity: 0;
  transform: scale(0.95);
  transition: all 0.3s ease;
}

.gallery-card.fade-in {
  opacity: 1;
  transform: scale(1);
  transition: all 0.3s ease;
}

/* Enhanced responsive grid */
@media (min-width: 640px) {
  .gallery-grid {
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  }
}

@media (min-width: 1024px) {
  .gallery-grid {
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
  }
}

@media (min-width: 1280px) {
  .gallery-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* Search input styling */
#gallery-search {
  transition: all 0.2s ease;
}

#gallery-search:focus {
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

/* Loading animation */
.gallery-loading {
  opacity: 0.6;
  pointer-events: none;
}

.gallery-loading::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20px;
  height: 20px;
  margin: -10px 0 0 -10px;
  border: 2px solid #f3f3f3;
  border-top: 2px solid #3498db;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Enhanced CTA section */
.text-center a {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.text-center a:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(59, 130, 246, 0.15);
}

/* Professional typography */
.gallery-header h2 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Dark mode enhancements */
@media (prefers-color-scheme: dark) {
  .gallery-controls {
    background: rgba(31, 41, 55, 0.8);
    border-color: rgba(75, 85, 99, 0.3);
  }
  
  .gallery-header h2 {
    background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
}
</style>

<script>
// Type declaration for Google Analytics gtag function
declare global {
  interface Window {
    gtag: (...args: any[]) => void;
  }
  var gtag: (...args: any[]) => void;
}

// Gallery Best Practices - Enhanced Functionality with Analytics
document.addEventListener('DOMContentLoaded', function() {
  const galleryGrid = document.getElementById('gallery-grid');
  const searchInput = document.getElementById('gallery-search') as HTMLInputElement;
  const filterButtons = document.querySelectorAll('.filter-btn');
  const noResults = document.getElementById('no-results');
  
  let currentFilter = 'all';
  let currentSearch = '';
  let searchTimeout: ReturnType<typeof setTimeout>;
  
  // Analytics helper function
  function trackEvent(eventName: string, eventData: any = {}) {
    // Google Analytics 4 tracking
    if (typeof gtag !== 'undefined') {
      gtag('event', eventName, {
        event_category: 'gallery_engagement',
        ...eventData
      });
    }
    
    // Additional analytics providers can be added here
    console.log(`Analytics: ${eventName}`, eventData);
  }
  
  // Track initial gallery view
  trackEvent('gallery_page_view', {
    total_projects: document.querySelectorAll('.gallery-card').length,
    timestamp: new Date().toISOString()
  });
  
  // Filter functionality with analytics and accessibility
  filterButtons.forEach(button => {
    button.addEventListener('click', function(this: HTMLButtonElement) {
      // Update active button and ARIA states
      filterButtons.forEach(btn => {
        btn.classList.remove('active');
        btn.setAttribute('aria-pressed', 'false');
      });
      this.classList.add('active');
      this.setAttribute('aria-pressed', 'true');
      
      const previousFilter = currentFilter;
      currentFilter = this.dataset.filter!;
      
      // Track filter usage
      trackEvent('gallery_filter_used', {
        filter_from: previousFilter,
        filter_to: currentFilter,
        timestamp: new Date().toISOString()
      });
      
      filterGallery();
    });
  });
  
  // Search functionality with debouncing and analytics
  searchInput?.addEventListener('input', function() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      const previousSearch = currentSearch;
      currentSearch = this.value.toLowerCase().trim();
      
      // Track search behavior
      if (currentSearch && currentSearch !== previousSearch) {
        trackEvent('gallery_search_performed', {
          search_term: currentSearch,
          search_length: currentSearch.length,
          timestamp: new Date().toISOString()
        });
      }
      
      filterGallery();
    }, 300);
  });
  
  function filterGallery() {
    const cards = galleryGrid?.querySelectorAll('.gallery-card') as NodeListOf<HTMLElement>;
    let visibleCount = 0;
    const startTime = performance.now();
    
    cards?.forEach(card => {
      const title = card.dataset.title?.toLowerCase() || '';
      const description = card.dataset.description?.toLowerCase() || '';
      const category = card.dataset.category?.toLowerCase() || '';
      const techStack = card.dataset.techStack ? 
        JSON.parse(card.dataset.techStack).join(' ').toLowerCase() : '';
      
      // Check filter match
      const filterMatch = currentFilter === 'all' || category === currentFilter;
      
      // Check search match
      const searchMatch = !currentSearch || 
        title.includes(currentSearch) || 
        description.includes(currentSearch) || 
        techStack.includes(currentSearch) ||
        category.includes(currentSearch);
      
      if (filterMatch && searchMatch) {
        card.classList.remove('hidden', 'fade-out');
        card.classList.add('fade-in');
        visibleCount++;
      } else {
        card.classList.add('fade-out');
        setTimeout(() => {
          card.classList.add('hidden');
          card.classList.remove('fade-out', 'fade-in');
        }, 200);
      }
    });
    
    // Track filter performance and results
    const endTime = performance.now();
    trackEvent('gallery_filter_completed', {
      filter_applied: currentFilter,
      search_term: currentSearch,
      results_count: visibleCount,
      filter_duration_ms: Math.round(endTime - startTime),
      timestamp: new Date().toISOString()
    });
    
    // Show/hide no results message and announce to screen readers
    const announceElement = document.getElementById('filter-results-announcement');
    if (noResults) {
      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
        if (announceElement) {
          announceElement.textContent = `No projects found for the current filter: ${currentFilter}${currentSearch ? ` and search: ${currentSearch}` : ''}. Try adjusting your criteria.`;
        }
        trackEvent('gallery_no_results', {
          filter: currentFilter,
          search: currentSearch
        });
      } else {
        noResults.classList.add('hidden');
        if (announceElement) {
          const filterText = currentFilter === 'all' ? 'all categories' : currentFilter;
          const searchText = currentSearch ? ` matching "${currentSearch}"` : '';
          announceElement.textContent = `Showing ${visibleCount} project${visibleCount === 1 ? '' : 's'} in ${filterText}${searchText}.`;
        }
      }
    }
    
    // Update URL with current filters
    updateURL();
  }
  
  function updateURL() {
    const url = new URL(window.location.href);
    
    if (currentFilter !== 'all') {
      url.searchParams.set('category', currentFilter);
    } else {
      url.searchParams.delete('category');
    }
    
    if (currentSearch) {
      url.searchParams.set('search', currentSearch);
    } else {
      url.searchParams.delete('search');
    }
    
    // Update URL without reload
    window.history.replaceState({}, '', url);
  }
  
  // Initialize from URL parameters
  function initializeFromURL() {
    const url = new URL(window.location.href);
    const categoryParam = url.searchParams.get('category');
    const searchParam = url.searchParams.get('search');
    
    if (categoryParam) {
      currentFilter = categoryParam;
      const filterBtn = document.querySelector(`[data-filter="${categoryParam}"]`);
      if (filterBtn) {
        filterButtons.forEach(btn => btn.classList.remove('active'));
        filterBtn.classList.add('active');
      }
    }
    
    if (searchParam && searchInput) {
      currentSearch = searchParam;
      searchInput.value = searchParam;
    }
    
    if (categoryParam || searchParam) {
      trackEvent('gallery_url_parameters_loaded', {
        category: categoryParam,
        search: searchParam
      });
      filterGallery();
    }
  }
  
  // Enhanced keyboard shortcuts with analytics
  document.addEventListener('keydown', function(e) {
    // Focus search on '/' key
    if (e.key === '/' && !e.ctrlKey && !e.metaKey && searchInput) {
      e.preventDefault();
      searchInput.focus();
      trackEvent('gallery_keyboard_shortcut', {
        shortcut: 'search_focus',
        key: '/'
      });
    }
    
    // Clear search on 'Escape' key
    if (e.key === 'Escape' && searchInput === document.activeElement && searchInput) {
      searchInput.value = '';
      currentSearch = '';
      filterGallery();
      searchInput.blur();
      trackEvent('gallery_keyboard_shortcut', {
        shortcut: 'search_clear',
        key: 'Escape'
      });
    }
  });
  
  // Track gallery card interactions
  document.querySelectorAll('.gallery-card').forEach((card, index) => {
    card.addEventListener('click', function(this: HTMLElement) {
      trackEvent('gallery_card_clicked', {
        project_title: this.dataset.title,
        project_category: this.dataset.category,
        card_position: index + 1,
        current_filter: currentFilter,
        current_search: currentSearch,
        timestamp: new Date().toISOString()
      });
    });
    
    // Track hover interactions for engagement
    let hoverStartTime: number;
    card.addEventListener('mouseenter', function() {
      hoverStartTime = Date.now();
    });
    
    card.addEventListener('mouseleave', function(this: HTMLElement) {
      if (hoverStartTime) {
        const hoverDuration = Date.now() - hoverStartTime;
        if (hoverDuration > 1000) { // Only track meaningful hovers
          trackEvent('gallery_card_hover', {
            project_title: this.dataset.title,
            hover_duration_ms: hoverDuration,
            card_position: index + 1
          });
        }
      }
    });
  });
  
  // Track external link clicks
  document.querySelectorAll('a[href^="http"]').forEach(link => {
    link.addEventListener('click', function(this: HTMLAnchorElement, e) {
      const href = this.getAttribute('href');
      const linkText = this.textContent?.trim();
      
      trackEvent('external_link_clicked', {
        link_url: href,
        link_text: linkText,
        link_context: 'gallery_page',
        timestamp: new Date().toISOString()
      });
    });
  });
  
  // Initialize
  initializeFromURL();
  
  // Enhanced Performance monitoring with Intersection Observer and Lazy Loading
  const performanceObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const card = entry.target as HTMLElement;
        
        // Add fade-in animation
        card.classList.add('animate-fade-in');
        
        // Lazy load images
        const images = card.querySelectorAll('img[data-src]');
        images.forEach((img) => {
          const imageElement = img as HTMLImageElement;
          if (imageElement.dataset.src) {
            imageElement.src = imageElement.dataset.src;
            imageElement.removeAttribute('data-src');
            imageElement.classList.add('loaded');
          }
        });
        
        // Load background images
        if (card.dataset.bgImage) {
          card.style.backgroundImage = `url(${card.dataset.bgImage})`;
          card.removeAttribute('data-bg-image');
        }
        
        // Track performance metrics
        const projectTitle = card.dataset.title;
        if (projectTitle) {
          trackEvent('gallery_card_viewed', {
            project_title: projectTitle,
            view_timestamp: new Date().toISOString(),
            load_time: performance.now() - window.performance.timing.navigationStart
          });
        }
        
        // Stop observing this element
        performanceObserver.unobserve(card);
      }
    });
  }, {
    threshold: 0.1,
    rootMargin: '0px 0px -100px 0px'
  });
  
  // Priority loading observer for above-the-fold content
  const priorityObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const card = entry.target as HTMLElement;
        card.style.transform = 'translateY(0)';
        card.style.opacity = '1';
        priorityObserver.unobserve(card);
      }
    });
  }, {
    threshold: 0.2,
    rootMargin: '50px'
  });
  
  // Observe gallery cards with performance optimization
  document.querySelectorAll('.gallery-card').forEach((card, index) => {
    const cardElement = card as HTMLElement;
    
    // Prioritize first 6 cards for immediate loading
    if (index < 6) {
      priorityObserver.observe(cardElement);
      // Pre-load critical images immediately
      const criticalImages = cardElement.querySelectorAll('img[data-src]');
      criticalImages.forEach((img) => {
        const imageElement = img as HTMLImageElement;
        if (imageElement.dataset.src) {
          imageElement.src = imageElement.dataset.src;
          imageElement.removeAttribute('data-src');
        }
      });
    } else {
      // Lazy load remaining cards
      cardElement.style.transform = 'translateY(20px)';
      cardElement.style.opacity = '0.3';
      performanceObserver.observe(cardElement);
    }
  });
  
  // Preload critical resources
  function preloadCriticalResources() {
    const criticalImages = Array.from(document.querySelectorAll('.gallery-card')).slice(0, 3);
    criticalImages.forEach(card => {
      const img = (card as HTMLElement).querySelector('img');
      if (img && img.src) {
        const link = document.createElement('link');
        link.rel = 'preload';
        link.as = 'image';
        link.href = img.src;
        document.head.appendChild(link);
      }
    });
  }
  
  // Initialize critical resource preloading
  preloadCriticalResources();
  
  // Page visibility tracking
  document.addEventListener('visibilitychange', function() {
    if (document.hidden) {
      trackEvent('gallery_page_hidden', {
        time_on_page: Date.now() - window.performance.timing.navigationStart,
        current_filter: currentFilter,
        current_search: currentSearch
      });
    } else {
      trackEvent('gallery_page_visible', {
        timestamp: new Date().toISOString()
      });
    }
  });
  
  // Track page unload
  window.addEventListener('beforeunload', function() {
    trackEvent('gallery_page_exit', {
      time_on_page: Date.now() - window.performance.timing.navigationStart,
      interactions_performed: {
        filter_changes: currentFilter !== 'all',
        search_performed: currentSearch.length > 0
      }
    });
  });
});
</script>

<style>
/* Gallery Performance & Animation Styles */
.gallery-container {
  contain: layout style paint;
}

.gallery-grid {
  contain: layout;
}

.gallery-card {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform, opacity;
  transform: translateZ(0); /* Force hardware acceleration */
}

.gallery-card:hover {
  transform: translateY(-4px) translateZ(0);
}

/* Enhanced Loading States */
.gallery-card img {
  transition: opacity 0.3s ease;
  opacity: 0;
}

.gallery-card img.loaded {
  opacity: 1;
}

.gallery-card img[data-src] {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Performance optimizations */
.fade-in {
  animation: fadeIn 0.4s ease-out forwards;
}

.fade-out {
