                    class="gallery-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8"
                    role="region"
                    aria-label={`Gallery displaying ${len} project${len === 1 ? '' : 's'}`}
                    aria-live="polite"
