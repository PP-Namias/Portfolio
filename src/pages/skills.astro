---
import Layout from '../layouts/Layout.astro';
import MainGridLayout from '../layouts/MainGridLayout.astro';
---

<Layout title="Skills - PP Namias">
    <MainGridLayout>
        <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
            <div class="card-base z-10 px-9 py-6 relative w-full">
                <div class="prose">
                    <h1 class="text-3xl font-bold mb-8">Technical Skills</h1>
                    
                    <!-- Frontend Skills -->
                    <section class="mb-8">
                        <h2 class="text-2xl font-semibold mb-4">Frontend Development</h2>
                        <div class="space-y-4">
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">HTML/CSS</span>
                                    <span class="text-sm text-gray-600">90%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-blue-600 h-2 rounded-full" style="width: 90%"></div>
                                </div>
                            </div>
                            
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">JavaScript/TypeScript</span>
                                    <span class="text-sm text-gray-600">85%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-blue-600 h-2 rounded-full" style="width: 85%"></div>
                                </div>
                            </div>
                            
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">React</span>
                                    <span class="text-sm text-gray-600">80%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-blue-600 h-2 rounded-full" style="width: 80%"></div>
                                </div>
                            </div>
                            
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">Astro</span>
                                    <span class="text-sm text-gray-600">75%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-blue-600 h-2 rounded-full" style="width: 75%"></div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Backend Skills -->
                    <section class="mb-8">
                        <h2 class="text-2xl font-semibold mb-4">Backend Development</h2>
                        <div class="space-y-4">
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">Node.js</span>
                                    <span class="text-sm text-gray-600">78%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-green-600 h-2 rounded-full" style="width: 78%"></div>
                                </div>
                            </div>
                            
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">Python</span>
                                    <span class="text-sm text-gray-600">70%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-green-600 h-2 rounded-full" style="width: 70%"></div>
                                </div>
                            </div>
                            
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">Database (SQL/NoSQL)</span>
                                    <span class="text-sm text-gray-600">75%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-green-600 h-2 rounded-full" style="width: 75%"></div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Tools & Technologies -->
                    <section class="mb-8">
                        <h2 class="text-2xl font-semibold mb-4">Tools & Technologies</h2>
                        <div class="space-y-4">
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">Git/GitHub</span>
                                    <span class="text-sm text-gray-600">88%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-purple-600 h-2 rounded-full" style="width: 88%"></div>
                                </div>
                            </div>
                            
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">VS Code</span>
                                    <span class="text-sm text-gray-600">95%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-purple-600 h-2 rounded-full" style="width: 95%"></div>
                                </div>
                            </div>
                            
                            <div class="skill-item">
                                <div class="flex justify-between mb-2">
                                    <span class="font-medium">Docker</span>
                                    <span class="text-sm text-gray-600">65%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-purple-600 h-2 rounded-full" style="width: 65%"></div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Soft Skills -->
                    <section>
                        <h2 class="text-2xl font-semibold mb-4">Professional Skills</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="skill-tag bg-blue-100 text-blue-800 px-3 py-2 rounded-lg">
                                Problem Solving
                            </div>
                            <div class="skill-tag bg-green-100 text-green-800 px-3 py-2 rounded-lg">
                                Team Collaboration
                            </div>
                            <div class="skill-tag bg-purple-100 text-purple-800 px-3 py-2 rounded-lg">
                                Project Management
                            </div>
                            <div class="skill-tag bg-orange-100 text-orange-800 px-3 py-2 rounded-lg">
                                Continuous Learning
                            </div>
                            <div class="skill-tag bg-teal-100 text-teal-800 px-3 py-2 rounded-lg">
                                Code Review
                            </div>
                            <div class="skill-tag bg-indigo-100 text-indigo-800 px-3 py-2 rounded-lg">
                                Technical Writing
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </MainGridLayout>
</Layout>

<style>
    .skill-item {
        padding: 0.5rem 0;
    }
    
    .skill-tag {
        text-align: center;
        font-weight: 500;
        transition: transform 0.2s ease;
    }
    
    .skill-tag:hover {
        transform: translateY(-2px);
    }
</style>