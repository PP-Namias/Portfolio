---
// Archived: src/pages/skills-analytics.astro
import SkillsAnalyticsDashboard from "@components/archived/SkillsAnalytics.astro";
import Layout from "../layouts/Layout.astro";

const pageTitle = "Skills Analytics Dashboard (Archived)";
const pageDescription = "Archived analytics dashboard.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen">
    <section class="pt-24 pb-12">
      <div class="container mx-auto px-6">
        <div class="text-center max-w-4xl mx-auto">
          <h1>{pageTitle}</h1>
        </div>
      </div>
    </section>

    <section class="pb-24">
      <div class="container mx-auto px-6">
        <SkillsAnalyticsDashboard />
      </div>
    </section>
  </main>
</Layout>
