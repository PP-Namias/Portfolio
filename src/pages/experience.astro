---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const experiencePost = await getEntry("spec", "experience");

if (!experiencePost) {
	throw new Error("Experience page content not found");
}

const { Content } = await render(experiencePost);
---

<MainGridLayout title="Experience - Jhon Keneth Namias" description="My professional journey and achievements">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>

<style>
    /* Enhanced styling for experience content */
    :global(.card-base h1) {
        @apply text-4xl font-bold mb-8 text-center;
    }
    
    :global(.card-base h2) {
        @apply text-2xl font-semibold mb-4 mt-8 text-blue-600;
    }
    
    :global(.card-base h3) {
        @apply text-lg font-medium mb-2 text-gray-700;
    }
    
    :global(.card-base p) {
        @apply text-gray-600 leading-relaxed mb-4;
    }
    
    :global(.card-base strong) {
        @apply font-semibold text-gray-800;
    }
    
    :global(.card-base ul) {
        @apply list-disc list-inside space-y-2 mb-4 text-gray-600;
    }
    
    :global(.card-base li) {
        @apply leading-relaxed;
    }
    
    :global(.card-base hr) {
        @apply border-gray-200 my-8;
    }
    
    /* Technology tags styling */
    :global(.card-base p:has(strong:contains("Technologies:"))) {
        @apply bg-gray-50 p-4 rounded-lg border-l-4 border-blue-500;
    }
    
    /* Achievement lists styling */
    :global(.card-base p:has(strong:contains("Key Achievements:")) + ul) {
        @apply bg-green-50 p-4 rounded-lg border-l-4 border-green-500;
    }
    
    /* Certification sections */
    :global(.card-base h3:contains("Certified")) {
        @apply text-purple-600 font-semibold;
    }
    
    /* Career highlights section */
    :global(.card-base p:has(strong:contains("Years Experience"))) {
        @apply bg-gradient-to-r from-blue-50 to-purple-50 p-6 rounded-xl border border-blue-200;
    }
    
    /* Responsive design */
    @media (max-width: 768px) {
        :global(.card-base) {
            @apply px-6 py-4;
        }
        
        :global(.card-base h1) {
            @apply text-3xl;
        }
        
        :global(.card-base h2) {
            @apply text-xl;
        }
    }
</style>
                                    <li>Built responsive web applications serving 10,000+ users</li>
                                    <li>Reduced page load times by 50% through code optimization</li>
                                    <li>Collaborated with design team on 15+ project implementations</li>
                                    <li>Established component library used across multiple projects</li>
                                </ul>
                                <div class="tech-tags mt-3">
                                    <span class="tech-tag">Vue.js</span>
                                    <span class="tech-tag">JavaScript</span>
                                    <span class="tech-tag">SASS</span>
                                    <span class="tech-tag">Webpack</span>
                                </div>
                            </div>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-marker"></div>
                            <div class="timeline-content">
                                <div class="timeline-date">2021 - 2022</div>
                                <h3 class="text-xl font-semibold mb-2">Junior Web Developer</h3>
                                <h4 class="text-lg text-gray-600 mb-3">First Company</h4>
                                <p class="mb-3">
                                    Started my professional journey learning best practices in web development.
                                    Contributed to various projects while building foundational skills.
                                </p>
                                <ul class="list-disc ml-5 space-y-1 text-sm">
                                    <li>Assisted in developing 8+ client websites</li>
                                    <li>Learned agile development methodologies</li>
                                    <li>Participated in daily standups and sprint planning</li>
                                    <li>Maintained and updated legacy codebases</li>
                                </ul>
                                <div class="tech-tags mt-3">
                                    <span class="tech-tag">HTML</span>
                                    <span class="tech-tag">CSS</span>
                                    <span class="tech-tag">JavaScript</span>
                                    <span class="tech-tag">PHP</span>
                                </div>
                            </div>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-marker"></div>
                            <div class="timeline-content">
                                <div class="timeline-date">2020 - 2021</div>
                                <h3 class="text-xl font-semibold mb-2">Self-Taught Developer</h3>
                                <h4 class="text-lg text-gray-600 mb-3">Personal Projects & Learning</h4>
                                <p class="mb-3">
                                    Dedicated time to learning programming fundamentals and building personal projects.
                                    Completed online courses and contributed to open-source projects.
                                </p>
                                <ul class="list-disc ml-5 space-y-1 text-sm">
                                    <li>Completed 10+ online programming courses</li>
                                    <li>Built 5+ personal projects from scratch</li>
                                    <li>Contributed to 3 open-source repositories</li>
                                    <li>Created personal portfolio website</li>
                                </ul>
                                <div class="tech-tags mt-3">
                                    <span class="tech-tag">Python</span>
                                    <span class="tech-tag">JavaScript</span>
                                    <span class="tech-tag">Git</span>
                                    <span class="tech-tag">Linux</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Certifications Section -->
                    <section class="mt-12">
                        <h2 class="text-2xl font-semibold mb-6">Certifications</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="cert-card p-4 border rounded-lg hover:shadow-lg transition-shadow">
                                <h3 class="font-semibold">AWS Certified Developer</h3>
                                <p class="text-sm text-gray-600">Amazon Web Services • 2023</p>
                            </div>
                            <div class="cert-card p-4 border rounded-lg hover:shadow-lg transition-shadow">
                                <h3 class="font-semibold">React Developer Certification</h3>
                                <p class="text-sm text-gray-600">Meta • 2022</p>
                            </div>
                            <div class="cert-card p-4 border rounded-lg hover:shadow-lg transition-shadow">
                                <h3 class="font-semibold">JavaScript Algorithms & Data Structures</h3>
                                <p class="text-sm text-gray-600">freeCodeCamp • 2021</p>
                            </div>
                            <div class="cert-card p-4 border rounded-lg hover:shadow-lg transition-shadow">
                                <h3 class="font-semibold">Responsive Web Design</h3>
                                <p class="text-sm text-gray-600">freeCodeCamp • 2020</p>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </MainGridLayout>
</Layout>

<style>
    .timeline-container {
        position: relative;
        padding-left: 2rem;
    }
    
    .timeline-container::before {
        content: '';
        position: absolute;
        left: 0.75rem;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(to bottom, #3b82f6, #8b5cf6);
    }
    
    .timeline-item {
        position: relative;
        margin-bottom: 2rem;
        padding-left: 2rem;
    }
    
    .timeline-marker {
        position: absolute;
        left: -2rem;
        top: 0.5rem;
        width: 1rem;
        height: 1rem;
        background: #3b82f6;
        border: 3px solid white;
        border-radius: 50%;
        box-shadow: 0 0 0 4px #e5e7eb;
    }
    
    .timeline-content {
        background: white;
        padding: 1.5rem;
        border-radius: 0.75rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        border: 1px solid #e5e7eb;
    }
    
    .timeline-date {
        color: #6b7280;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .tech-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    
    .tech-tag {
        background: #f3f4f6;
        color: #374151;
        padding: 0.25rem 0.75rem;
        border-radius: 1rem;
        font-size: 0.75rem;
        font-weight: 500;
    }
    
    .cert-card {
        transition: all 0.2s ease;
    }
    
    .cert-card:hover {
        transform: translateY(-2px);
    }
</style>