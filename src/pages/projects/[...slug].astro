---
import path from "node:path";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
	const projectEntries = await getCollection("projects");
	return projectEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CreativeWork",
	name: entry.data.title,
	description: entry.data.description || entry.data.title,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout 
	banner={entry.data.image} 
	title={entry.data.title} 
	description={entry.data.description}
	headings={headings}
>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			
			<!-- Project Header -->
			<div class="mb-8 border-b border-gray-200 pb-6">
				<div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6">
					<div class="flex-1">
						<h1 class="text-4xl font-bold text-gray-900 mb-2">{entry.data.title}</h1>
						<p class="text-xl text-gray-600 leading-relaxed">{entry.data.description}</p>
					</div>
					
					{entry.data.featured && (
						<div class="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-full text-sm font-semibold">
							<Icon name="fa6-solid:star" class="w-4 h-4" />
							Featured Project
						</div>
					)}
				</div>
				
				<!-- Project Metadata -->
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
					<div class="flex items-center gap-2 text-gray-600">
						<Icon name="fa6-solid:calendar" class="w-4 h-4" />
						<span class="text-sm">Published {formatDateToYYYYMMDD(entry.data.published)}</span>
					</div>
					
					{entry.data.category && (
						<div class="flex items-center gap-2 text-gray-600">
							<Icon name="fa6-solid:folder" class="w-4 h-4" />
							<span class="text-sm">{entry.data.category}</span>
						</div>
					)}
					
					<div class="flex items-center gap-2 text-gray-600">
						<Icon name="fa6-solid:code" class="w-4 h-4" />
						<span class="text-sm capitalize">{entry.data.status}</span>
					</div>
					
					{entry.data.updated && (
						<div class="flex items-center gap-2 text-gray-600">
							<Icon name="fa6-solid:clock-rotate-left" class="w-4 h-4" />
							<span class="text-sm">Updated {formatDateToYYYYMMDD(entry.data.updated)}</span>
						</div>
					)}
				</div>
				
				<!-- Technologies -->
				{entry.data.technologies && entry.data.technologies.length > 0 && (
					<div class="mb-6">
						<h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">
							<Icon name="fa6-solid:gear" class="w-5 h-5" />
							Technologies Used
						</h3>
						<div class="flex flex-wrap gap-2">
							{entry.data.technologies.map((tech) => (
								<span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-medium hover:bg-blue-200 transition-colors">
									{tech}
								</span>
							))}
						</div>
					</div>
				)}
				
				<!-- Action Buttons -->
				<div class="flex flex-wrap gap-4">
					{entry.data.demoUrl && (
						<a 
							href={entry.data.demoUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-green-500 to-green-600 text-white font-semibold rounded-lg hover:from-green-600 hover:to-green-700 transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl"
						>
							<Icon name="fa6-solid:external-link" class="w-4 h-4" />
							Live Demo
						</a>
					)}
					
					{entry.data.codeUrl && (
						<a 
							href={entry.data.codeUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-gray-700 to-gray-800 text-white font-semibold rounded-lg hover:from-gray-800 hover:to-gray-900 transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl"
						>
							<Icon name="fa6-brands:github" class="w-4 h-4" />
							View Code
						</a>
					)}
					
					<button 
						onclick="navigator.share ? navigator.share({title: document.title, url: window.location.href}) : navigator.clipboard.writeText(window.location.href)"
						class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold rounded-lg hover:from-blue-600 hover:to-blue-700 transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl"
					>
						<Icon name="fa6-solid:share" class="w-4 h-4" />
						Share Project
					</button>
				</div>
			</div>
			
			<!-- Project Content -->
			<Markdown class="project-content">
				<Content />
			</Markdown>
			
			<!-- Back to Projects Navigation -->
			<div class="mt-12 pt-8 border-t border-gray-200">
				<a 
					href="/projects/"
					class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-semibold transition-colors"
				>
					<Icon name="fa6-solid:arrow-left" class="w-4 h-4" />
					Back to All Projects
				</a>
			</div>
		</div>
	</div>
</MainGridLayout>

<style>
	/* Enhanced styling for project content */
	:global(.project-content) {
		@apply max-w-none;
	}
	
	:global(.project-content h1) {
		@apply text-3xl font-bold mt-12 mb-6 text-gray-900 border-b border-gray-200 pb-4;
	}
	
	:global(.project-content h2) {
		@apply text-2xl font-semibold mt-10 mb-5 text-gray-800 flex items-center gap-3;
	}
	
	:global(.project-content h3) {
		@apply text-xl font-semibold mt-8 mb-4 text-gray-800;
	}
	
	:global(.project-content h4) {
		@apply text-lg font-semibold mt-6 mb-3 text-gray-700;
	}
	
	:global(.project-content p) {
		@apply text-gray-600 leading-relaxed mb-4 text-base;
	}
	
	:global(.project-content strong) {
		@apply font-semibold text-gray-800;
	}
	
	:global(.project-content ul) {
		@apply list-disc list-inside mb-4 space-y-2;
	}
	
	:global(.project-content ol) {
		@apply list-decimal list-inside mb-4 space-y-2;
	}
	
	:global(.project-content li) {
		@apply text-gray-600 leading-relaxed;
	}
	
	:global(.project-content blockquote) {
		@apply border-l-4 border-blue-500 pl-6 py-4 my-6 bg-blue-50 rounded-r-lg;
	}
	
	:global(.project-content code:not(pre code)) {
		@apply bg-gray-100 px-2 py-1 rounded text-sm font-mono text-gray-800;
	}
	
	:global(.project-content pre) {
		@apply bg-gray-900 text-gray-100 p-6 rounded-lg mb-6 overflow-x-auto;
	}
	
	:global(.project-content pre code) {
		@apply bg-transparent p-0 rounded-none text-sm;
	}
	
	:global(.project-content img) {
		@apply rounded-lg shadow-lg mb-6 w-full max-w-4xl mx-auto;
	}
	
	:global(.project-content a) {
		@apply text-blue-600 hover:text-blue-800 underline transition-colors;
	}
	
	:global(.project-content hr) {
		@apply border-gray-200 my-12;
	}
	
	/* Table styling */
	:global(.project-content table) {
		@apply w-full mb-6 border-collapse border border-gray-200 rounded-lg overflow-hidden;
	}
	
	:global(.project-content th) {
		@apply bg-gray-50 text-gray-800 font-semibold p-3 border border-gray-200 text-left;
	}
	
	:global(.project-content td) {
		@apply p-3 border border-gray-200 text-gray-600;
	}
	
	/* Special styling for emoji headings */
	:global(.project-content h2:has-text('🎯'),
	:global(.project-content h2:has-text('✨')),
	:global(.project-content h2:has-text('🛠')),
	:global(.project-content h2:has-text('📊')),
	:global(.project-content h2:has-text('🚀'))) {
		@apply bg-gradient-to-r from-blue-500 to-purple-600 bg-clip-text text-transparent;
	}
	
	/* Performance metrics styling */
	:global(.project-content h3:contains("Performance"),
	:global(.project-content h3:contains("Metrics")),
	:global(.project-content h3:contains("Results"))) {
		@apply text-green-700;
	}
	
	/* Technical sections styling */
	:global(.project-content h3:contains("Technical"),
	:global(.project-content h3:contains("Architecture")),
	:global(.project-content h3:contains("Implementation"))) {
		@apply text-blue-700;
	}
	
	/* Responsive design */
	@media (max-width: 768px) {
		:global(.project-content) {
			@apply text-sm;
		}
		
		:global(.project-content h1) {
			@apply text-2xl;
		}
		
		:global(.project-content h2) {
			@apply text-xl;
		}
		
		:global(.project-content h3) {
			@apply text-lg;
		}
		
		:global(.project-content pre) {
			@apply p-4 text-xs;
		}
	}
</style>