---
// Skills Analytics Page
// src/pages/skills-analytics.astro
import Layout from "../layouts/Layout.astro";
import SkillsAnalyticsDashboard from "../components/SkillsAnalytics.astro";
import { siteConfig } from "../config";

const pageTitle = "Skills Analytics Dashboard";
const pageDescription = "Comprehensive analysis of technical expertise, skill development tracking, and learning progress insights.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 dark:from-gray-900 dark:via-blue-900 dark:to-indigo-900">
    <!-- Hero Section -->
    <section class="pt-24 pb-12">
      <div class="container mx-auto px-6">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-6xl font-bold bg-gradient-to-r from-blue-600 via-purple-600 to-indigo-600 bg-clip-text text-transparent mb-6">
            Skills Analytics
          </h1>
          <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 leading-relaxed mb-8">
            Data-driven insights into technical expertise, growth patterns, and learning trajectory
          </p>
          <div class="flex flex-wrap justify-center gap-4 mb-12">
            <div class="analytics-badge">
              <span class="badge-icon">📊</span>
              <span>Real-time Analytics</span>
            </div>
            <div class="analytics-badge">
              <span class="badge-icon">📈</span>
              <span>Growth Tracking</span>
            </div>
            <div class="analytics-badge">
              <span class="badge-icon">🎯</span>
              <span>Goal Management</span>
            </div>
            <div class="analytics-badge">
              <span class="badge-icon">🔍</span>
              <span>Detailed Insights</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Analytics Dashboard -->
    <section class="pb-24">
      <div class="container mx-auto px-6">
        <SkillsAnalyticsDashboard />
      </div>
    </section>

    <!-- Additional Insights Section -->
    <section class="py-16 bg-white/50 dark:bg-gray-800/50 backdrop-blur-sm">
      <div class="container mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
            Advanced Analytics Features
          </h2>
          <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
            Explore detailed insights and advanced analytics tools for comprehensive skill assessment
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Skill Progression Timeline -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 3v18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M18 9l-5 5-4-4-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-title">Skill Progression</h3>
            <p class="feature-description">
              Track skill development over time with detailed progression timelines and milestone achievements.
            </p>
          </div>

          <!-- Competency Matrix -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M3 9h18" stroke="currentColor" stroke-width="2"/>
                <path d="M9 21V9" stroke="currentColor" stroke-width="2"/>
              </svg>
            </div>
            <h3 class="feature-title">Competency Matrix</h3>
            <p class="feature-description">
              Visualize skill relationships and identify complementary technologies for strategic learning paths.
            </p>
          </div>

          <!-- Performance Benchmarks -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-title">Industry Benchmarks</h3>
            <p class="feature-description">
              Compare skill levels against industry standards and identify areas for competitive advantage.
            </p>
          </div>

          <!-- Learning ROI -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-title">Learning ROI</h3>
            <p class="feature-description">
              Analyze the return on investment for learning initiatives and optimize educational resources.
            </p>
          </div>

          <!-- Team Collaboration -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-title">Team Insights</h3>
            <p class="feature-description">
              Understand skill complementarity in team environments and identify collaboration opportunities.
            </p>
          </div>

          <!-- Predictive Analytics -->
          <div class="feature-card">
            <div class="feature-icon">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="3.27,6.96 12,12.01 20.73,6.96" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="12" y1="22.08" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-title">Future Projections</h3>
            <p class="feature-description">
              Leverage predictive analytics to forecast skill demand and plan strategic learning investments.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .analytics-badge {
    @apply inline-flex items-center gap-2 px-4 py-2 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm;
    @apply rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300;
    @apply transition-all duration-200 hover:scale-105 hover:shadow-md;
  }

  .badge-icon {
    @apply text-lg;
  }

  .feature-card {
    @apply bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700;
    @apply shadow-sm hover:shadow-md transition-all duration-200 hover:-translate-y-1;
  }

  .feature-icon {
    @apply w-16 h-16 bg-gradient-to-br from-blue-500 to-purple-600 rounded-xl;
    @apply flex items-center justify-center text-white mb-4;
  }

  .feature-title {
    @apply text-xl font-bold text-gray-900 dark:text-white mb-3;
  }

  .feature-description {
    @apply text-gray-600 dark:text-gray-400 leading-relaxed;
  }

  /* Animations */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .analytics-badge:nth-child(1) { animation: float 6s ease-in-out infinite; }
  .analytics-badge:nth-child(2) { animation: float 6s ease-in-out infinite 1.5s; }
  .analytics-badge:nth-child(3) { animation: float 6s ease-in-out infinite 3s; }
  .analytics-badge:nth-child(4) { animation: float 6s ease-in-out infinite 4.5s; }

  /* Responsive Design */
  @media (max-width: 768px) {
    .analytics-badge {
      @apply w-full justify-center;
    }
  }
</style>