# 🔧 Environment Configuration Template
# Copy this to apps/web/.env after setting up your Sanity project

# ===== YOUR NEW SANITY CMS CONFIGURATION =====
# Replace these values with your actual Sanity project details

# Your Sanity Project ID (get this from sanity manage or the Sanity dashboard)
VITE_SANITY_PROJECT_ID=your-new-project-id-here

# Dataset (usually 'production')
VITE_SANITY_DATASET=production

# Optional: API Token (only needed for preview mode or private datasets)
# Get this from: https://sanity.io/manage -> Your Project -> API -> Tokens
# VITE_SANITY_TOKEN=your-api-token-here

# ===== INSTRUCTIONS =====
# 1. Run 'sanity init' to create your project
# 2. Get your project ID from the Sanity dashboard
# 3. Replace 'your-new-project-id-here' with your actual project ID
# 4. Save this file as apps/web/.env
# 5. Restart your development server

# ===== EXAMPLE =====
# VITE_SANITY_PROJECT_ID=abc123def
# VITE_SANITY_DATASET=production

# ===== YOUR CMS URLS =====
# After setup, your CMS will be available at:
# Studio: https://ppnamias-cms.sanity.studio/
# Dashboard: https://sanity.io/manage
