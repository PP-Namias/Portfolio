# Google Gemini API Key (get from https://aistudio.google.com/apikey)
# Private server secret (never expose or commit real values)
GOOGLE_GEMINI_API_KEY=your_key_here

# Optional durable chat rate limiting (private server secrets)
UPSTASH_REDIS_REST_URL=your_upstash_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Umami analytics (optional; enable only when values are set)
# Public client variables (safe to expose in browser)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_HOST_URL=https://api-gateway.umami.dev
NEXT_PUBLIC_UMAMI_DOMAINS=namias.tech
