{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "Preserve",
    "moduleDetection": "force",
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": ["apps/web/src/**/*.ts", "apps/web/src/**/*.tsx", "studio/**/*.ts", "server/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "packages/**/*", "apps/api/**/*", "apps/web/vite.config.ts", "apps/web/tsconfig.node.json"]
}
