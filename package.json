{
	"name": "PP_Namias",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"check": "astro check",
		"build": "astro build && pagefind --site dist",
		"preview": "astro preview",
		"astro": "astro",
		"astro:check": "astro check",
		"type-check": "tsc --noEmit --isolatedDeclarations",
		"new-post": "node scripts/new-post.js",
		"format": "biome format --write ./src",
		"lint": "biome check --write ./src",
		"biome:ci": "biome ci ./src --reporter=github",
		"biome:check": "biome check ./src",
		"biome:format": "biome format --write ./src",
		"ci:quality": "pnpm run biome:ci && pnpm run astro:check",
		"ci:build": "pnpm run ci:quality && pnpm run build",
		"preinstall": "npx only-allow pnpm",
		"test": "vitest",
		"test:unit": "vitest run --reporter=verbose",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
		"ci:test": "pnpm run test:unit && pnpm run test:e2e",
		"lighthouse": "lhci autorun",
		"accessibility": "pa11y-ci --sitemap http://localhost:4321/sitemap-index.xml"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.4",
		"@astrojs/rss": "^4.0.12",
		"@astrojs/sitemap": "^3.5.1",
		"@astrojs/svelte": "7.1.0",
		"@astrojs/tailwind": "^6.0.2",
		"@expressive-code/core": "^0.41.3",
		"@expressive-code/plugin-collapsible-sections": "^0.41.3",
		"@expressive-code/plugin-line-numbers": "^0.41.3",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/roboto": "^5.2.8",
		"@iconify-json/fa6-brands": "^1.2.6",
		"@iconify-json/fa6-regular": "^1.2.4",
		"@iconify-json/fa6-solid": "^1.2.4",
		"@iconify-json/material-symbols": "^1.2.39",
		"@iconify-json/simple-icons": "^1.2.53",
		"@iconify/svelte": "^4.2.0",
		"@swup/astro": "^1.7.0",
		"@tailwindcss/typography": "^0.5.19",
		"@vercel/analytics": "^1.5.0",
		"@vercel/speed-insights": "^1.2.0",
		"astro": "5.13.3",
		"astro-expressive-code": "^0.41.3",
		"astro-icon": "^1.1.5",
		"hastscript": "^9.0.1",
		"katex": "^0.16.22",
		"markdown-it": "^14.1.0",
		"mdast-util-to-string": "^4.0.0",
		"overlayscrollbars": "^2.11.5",
		"pagefind": "^1.3.0",
		"photoswipe": "^5.4.4",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-components": "^0.3.0",
		"rehype-katex": "^7.0.1",
		"rehype-slug": "^6.0.0",
		"remark-directive": "^3.0.1",
		"remark-directive-rehype": "^0.4.2",
		"remark-github-admonitions-to-directives": "^1.0.5",
		"remark-math": "^6.0.0",
		"remark-sectionize": "^2.1.0",
		"sanitize-html": "^2.17.0",
		"sharp": "^0.34.4",
		"simple-icons": "^15.16.0",
		"stylus": "^0.64.0",
		"svelte": "^5.38.2",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.9.2",
		"unist-util-visit": "^5.0.0"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.10.4",
		"@biomejs/biome": "2.2.4",
		"@lhci/cli": "^0.14.0",
		"@playwright/test": "^1.55.1",
		"@rollup/plugin-yaml": "^4.1.2",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.8",
		"@testing-library/user-event": "^14.5.2",
		"@types/hast": "^3.0.4",
		"@types/markdown-it": "^14.1.2",
		"@types/mdast": "^4.0.4",
		"@types/sanitize-html": "^2.16.0",
		"@vitest/coverage-v8": "^2.1.8",
		"@vitest/ui": "^2.1.8",
		"axe-core": "^4.10.2",
		"axe-playwright": "^2.0.3",
		"happy-dom": "^16.0.0",
		"js-yaml": "^4.1.0",
		"jsdom": "^25.0.1",
		"pa11y-ci": "^3.1.0",
		"postcss-import": "^16.1.1",
		"postcss-nesting": "^13.0.2",
		"vitest": "^2.1.8"
	},
	"packageManager": "pnpm@9.14.4",
	"pnpm": {
		"overrides": {
			"semver@>=7.0.0 <7.5.2": ">=7.5.2",
			"esbuild@<=0.24.2": ">=0.25.0",
			"cookie@<0.7.0": ">=0.7.0",
			"brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
			"form-data@>=4.0.0 <4.0.4": ">=4.0.4",
			"tmp@<=0.2.3": ">=0.2.4",
			"devalue@<5.3.2": ">=5.3.2",
			"vite@>=6.0.0 <=6.3.5": ">=6.3.6",
			"axios@<1.12.0": ">=1.12.0"
		}
	}
}
