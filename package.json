{
  "name": "ppnamias-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Professional portfolio website for PP Namias",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@ppnamias/web",
    "build": "npm run build --workspace=@ppnamias/web",
    "preview": "npm run preview --workspace=@ppnamias/web",
    "lint": "npm run lint --workspace=@ppnamias/web",
    "type-check": "npm run type-check --workspace=@ppnamias/web",
    "clean": "rimraf apps/web/dist node_modules/.cache"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PPNamias/PP-Namias-Portfolio.git"
  },
  "author": "PP Namias",
  "license": "MIT",
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "ajv": "^8.17.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.525.0",
    "react-hook-form": "^7.62.0",
    "react-intersection-observer": "^9.16.0",
    "use-debounce": "^10.0.5",
    "zod": "^4.0.17"
  }
}
